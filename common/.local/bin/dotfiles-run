#!/usr/bin/env bash
set -euo pipefail

usage() {
  printf 'Usage: %s <command> [args...]\n' "$(basename -- "$0")" >&2
}

script_dir() {
  cd "$(dirname "${BASH_SOURCE[0]}")" && pwd
}

expand_home_dir() {
  local value="$1"

  case "$value" in
    "~") printf '%s\n' "${HOME:-$value}" ;;
    \~/*) printf '%s/%s\n' "${HOME:-~}" "${value#\~/}" ;;
    *) printf '%s\n' "$value" ;;
  esac
}

resolve_command() {
  local command_name="$1"
  local candidate

  if [[ "$command_name" == */* ]]; then
    command_name="$(expand_home_dir "$command_name")"
    [[ -x "$command_name" ]] || return 1
    printf '%s\n' "$command_name"
    return 0
  fi

  if [[ -n "${HOME:-}" ]]; then
    for candidate in \
      "$HOME/.local/bin/$command_name" \
      "$HOME/dotfiles/common/.local/bin/$command_name"
    do
      if [[ -x "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
      fi
    done
  fi

  candidate="$(script_dir)/$command_name"
  if [[ -x "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  command -v -- "$command_name" 2>/dev/null
}

if [[ $# -lt 1 ]]; then
  usage
  exit 2
fi

command_name="$1"
shift

if ! resolved_command="$(resolve_command "$command_name")"; then
  printf 'Error: command not found in dotfiles paths or PATH: %s\n' "$command_name" >&2
  exit 127
fi

exec "$resolved_command" "$@"
