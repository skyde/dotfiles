#!/usr/bin/env bash
set -euo pipefail

in_ssh_session() {
  [[ -n "${SSH_CLIENT:-}" || -n "${SSH_TTY:-}" || -n "${SSH_CONNECTION:-}" ]]
}

content_file=$(mktemp)
trap 'rm -f "$content_file"' EXIT
cat >"$content_file"

if [[ -n "${TMUX:-}" ]] && command -v tmux >/dev/null 2>&1; then
  if tmux load-buffer -w - <"$content_file" 2>/dev/null; then
    exit 0
  fi
fi

if ! in_ssh_session; then
  if command -v pbcopy >/dev/null 2>&1; then
    pbcopy <"$content_file"
    exit 0
  fi

  if [[ -n "${WAYLAND_DISPLAY:-}" ]] && command -v wl-copy >/dev/null 2>&1; then
    wl-copy <"$content_file"
    exit 0
  fi

  if [[ -n "${DISPLAY:-}" ]] && command -v xclip >/dev/null 2>&1; then
    xclip -selection clipboard <"$content_file"
    exit 0
  fi

  if [[ -n "${DISPLAY:-}" ]] && command -v xsel >/dev/null 2>&1; then
    xsel --clipboard --input <"$content_file"
    exit 0
  fi
fi

encoded=$(base64 <"$content_file" | tr -d '\n')

trap '' SIGTTOU

if [[ -w /dev/tty ]]; then
  if [[ -n "${TMUX:-}" ]]; then
    printf "\033Ptmux;\033\033]52;c;%s\a\033\\" "$encoded" >/dev/tty
  else
    printf "\033]52;c;%s\a" "$encoded" >/dev/tty
  fi
  exit 0
fi

echo "No copy method available." >&2
exit 1
