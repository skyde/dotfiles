#!/usr/bin/env bash
set -euo pipefail

bin_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

resolve_copy_helper() {
  local helper

  if [[ -x "$bin_dir/osc-copy" ]]; then
    printf '%s\n' "$bin_dir/osc-copy"
    return 0
  fi

  if [[ -n "${HOME:-}" ]]; then
    for helper in \
      "$HOME/.local/bin/osc-copy" \
      "$HOME/dotfiles/common/.local/bin/osc-copy"
    do
      if [[ -x "$helper" ]]; then
        printf '%s\n' "$helper"
        return 0
      fi
    done
  fi

  if helper="$(command -v -- osc-copy 2>/dev/null)"; then
    printf '%s\n' "$helper"
    return 0
  fi

  return 1
}

lines=${1:-100}

if ! copy_helper="$(resolve_copy_helper)"; then
  printf 'copy-diff: osc-copy not found\n' >&2
  exit 127
fi

git diff -U"${lines}" "$(git merge-base HEAD origin/main)" | "$copy_helper"
