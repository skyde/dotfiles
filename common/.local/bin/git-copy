#!/usr/bin/env bash
set -euo pipefail

# Copy the diff between the current branch and its nearest base to the clipboard.
# Uses diff-branch to find the base and osc-copy to send to the terminal clipboard handler.

bin_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

resolve_copy_helper() {
  local helper

  for helper in \
    "$bin_dir/osc-copy" \
    "${HOME:-}/.local/bin/osc-copy" \
    "${HOME:-}/dotfiles/common/.local/bin/osc-copy"
  do
    if [[ -x "$helper" ]]; then
      printf '%s\n' "$helper"
      return 0
    fi
  done

  command -v -- osc-copy 2>/dev/null
}

if ! copy_helper="$(resolve_copy_helper)"; then
  printf 'git-copy: osc-copy not found\n' >&2
  exit 127
fi

diff-branch "$@" | "$copy_helper"
