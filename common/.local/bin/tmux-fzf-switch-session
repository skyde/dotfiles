#!/usr/bin/env bash
set -euo pipefail

TMUX_CLIENT_LIVE=0

ensure_usable_term() {
  if [[ -z "${TERM:-}" ]]; then
    export TERM=xterm-256color
  elif command -v infocmp >/dev/null 2>&1 && ! infocmp "$TERM" >/dev/null 2>&1; then
    export TERM=xterm-256color
  fi
}

display_tmux_message() {
  local message="$1"

  if [[ "$TMUX_CLIENT_LIVE" == "1" ]]; then
    tmux_cmd display-message "$message" 2>/dev/null || printf '%s\n' "$message" >&2
  else
    printf '%s\n' "$message" >&2
  fi
}

tmux_client_is_live() {
  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message -p '#{session_id}' >/dev/null 2>&1
  else
    return 1
  fi
}

tmux_cmd() {
  if [[ "$TMUX_CLIENT_LIVE" == "1" || -z "${TMUX:-}" ]]; then
    tmux "$@"
  else
    (unset TMUX; tmux "$@")
  fi
}

current_tmux_session_id() {
  [[ "$TMUX_CLIENT_LIVE" == "1" ]] || return 1
  tmux_cmd display-message -p '#{session_id}' 2>/dev/null
}

inside_tmux_client() {
  current_tmux_session_id >/dev/null
}

fallback_choose_tree() {
  if inside_tmux_client; then
    display_tmux_message "fzf unavailable; opening tmux choose-tree"
    if ! tmux_cmd choose-tree -sZ -O time; then
      display_tmux_message "Unable to open tmux choose-tree"
      return 1
    fi
  else
    display_tmux_message "fzf is required for tmux session switching"
    exit 1
  fi
}

script_path() {
  local source="${BASH_SOURCE[0]}"
  local source_dir source_base

  case "$source" in
    */*)
      source_dir="${source%/*}"
      source_base="${source##*/}"
      (cd -- "$source_dir" && printf '%s/%s\n' "$PWD" "$source_base")
      ;;
    *)
      if [[ -e "$source" ]]; then
        printf '%s/%s\n' "$PWD" "$source"
      else
        command -v -- "$source"
      fi
      ;;
  esac
}

session_header() {
  printf "%s\t%s\t%-22s\t%-14s\t%-9s\t%-9s\t%s\n" "ID" " " "SESSION" "WINDOW" "COUNT" "CLIENTS" "ACTIVE"
}

null_terminate_lines() {
  local line

  while IFS= read -r line || [[ -n "$line" ]]; do
    printf '%s\0' "$line"
  done
}

nul_to_lines() {
  local line

  while IFS= read -r -d '' line || [[ -n "$line" ]]; do
    printf '%s\n' "$line"
  done
}

line_count() {
  local value="$1"
  local line
  local count=0

  [[ -n "$value" ]] || {
    printf '0\n'
    return
  }

  while IFS= read -r line || [[ -n "$line" ]]; do
    count=$((count + 1))
  done <<<"$value"

  printf '%s\n' "$count"
}

last_nonempty_lines() {
  local limit="$1"
  local value="$2"
  local line
  local -a lines=()

  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue
    lines+=("$line")
    if ((${#lines[@]} > limit)); then
      lines=("${lines[@]:1}")
    fi
  done <<<"$value"

  ((${#lines[@]} == 0)) && return 0
  printf '%s\n' "${lines[@]}"
}

print_indented_lines() {
  local value="$1"
  local line

  while IFS= read -r line || [[ -n "$line" ]]; do
    printf '  %s\n' "$line"
  done <<<"$value"
}

session_age() {
  local now="$1" timestamp="$2" diff

  [[ "$now" =~ ^[0-9]+$ ]] || now=0
  [[ "$timestamp" =~ ^[0-9]+$ ]] || timestamp=0

  diff=$((now - timestamp))
  if ((diff < 0)); then
    diff=0
  fi

  if ((diff < 60)); then
    printf '%ss ago' "$diff"
  elif ((diff < 3600)); then
    printf '%sm ago' "$((diff / 60))"
  elif ((diff < 86400)); then
    printf '%sh ago' "$((diff / 3600))"
  else
    printf '%sd ago' "$((diff / 86400))"
  fi
}

session_row_before() {
  local candidate="$1" existing="$2" current_id="$3"
  local candidate_id candidate_name _candidate_windows _candidate_clients candidate_activity _candidate_window _candidate_command
  local existing_id existing_name _existing_windows _existing_clients existing_activity _existing_window _existing_command
  local candidate_current=0 existing_current=0

  IFS=$'\t' read -r candidate_id candidate_name _candidate_windows _candidate_clients candidate_activity _candidate_window _candidate_command <<<"$candidate"
  IFS=$'\t' read -r existing_id existing_name _existing_windows _existing_clients existing_activity _existing_window _existing_command <<<"$existing"

  [[ -n "$current_id" && "$candidate_id" == "$current_id" ]] && candidate_current=1
  [[ -n "$current_id" && "$existing_id" == "$current_id" ]] && existing_current=1

  if ((candidate_current < existing_current)); then
    return 0
  elif ((candidate_current > existing_current)); then
    return 1
  fi

  [[ "$candidate_activity" =~ ^[0-9]+$ ]] || candidate_activity=0
  [[ "$existing_activity" =~ ^[0-9]+$ ]] || existing_activity=0

  if ((candidate_activity > existing_activity)); then
    return 0
  elif ((candidate_activity < existing_activity)); then
    return 1
  fi

  [[ "$candidate_name" < "$existing_name" ]]
}

format_session_row() {
  local id="$1" name="$2" windows="$3" clients="$4" activity="$5" window="$6" command="$7" current_id="$8" now="$9"
  local marker=" " window_label windows_label clients_label active_label

  [[ -n "$current_id" && "$id" == "$current_id" ]] && marker="*"

  window_label="$window"
  [[ -n "$window_label" ]] || window_label="$command"
  [[ -n "$window_label" ]] || window_label="-"

  windows_label="$windows window"
  [[ "$windows" == "1" ]] || windows_label="$windows windows"

  if [[ "$clients" == "0" ]]; then
    clients_label="detached"
  else
    clients_label="$clients client"
    [[ "$clients" == "1" ]] || clients_label="$clients clients"
  fi

  active_label="$(session_age "$now" "$activity")"
  printf "%s\t%s\t%-22s\t%-14s\t%-9s\t%-9s\t%s\n" "$id" "$marker" "$name" "$window_label" "$windows_label" "$clients_label" "$active_label"
}

list_sessions() {
  local current_id now row inserted index
  local id name windows clients activity window command
  local -a rows=()

  current_id="$(current_tmux_session_id || true)"
  now="$(date +%s 2>/dev/null || true)"
  [[ "$now" =~ ^[0-9]+$ ]] || now=0

  while IFS=$'\t' read -r id name windows clients activity window command; do
    [[ -n "$id" ]] || continue
    row="${id}"$'\t'"${name}"$'\t'"${windows}"$'\t'"${clients}"$'\t'"${activity}"$'\t'"${window}"$'\t'"${command}"

    inserted=0
    for ((index = 0; index < ${#rows[@]}; index++)); do
      if session_row_before "$row" "${rows[$index]}" "$current_id"; then
        rows=("${rows[@]:0:index}" "$row" "${rows[@]:index}")
        inserted=1
        break
      fi
    done
    if [[ "$inserted" == "0" ]]; then
      rows+=("$row")
    fi
  done < <(tmux_cmd list-sessions -F $'#{session_id}\t#{=999:session_name}\t#{session_windows}\t#{session_attached}\t#{session_activity}\t#{=999:window_name}\t#{=999:pane_current_command}')

  for row in "${rows[@]}"; do
    IFS=$'\t' read -r id name windows clients activity window command <<<"$row"
    format_session_row "$id" "$name" "$windows" "$clients" "$activity" "$window" "$command" "$current_id" "$now"
  done
}

preview_session() {
  local target="$1"
  local active_output active_pane_id clients last_active name window_count window_word client_phrase

  if ! tmux_cmd has-session -t "$target" 2>/dev/null; then
    printf 'Session no longer exists: %s\n' "$target"
    return 0
  fi

  name="$(tmux_cmd display-message -p -t "$target" '#{=999:session_name}')"
  window_count="$(tmux_cmd display-message -p -t "$target" '#{session_windows}')"
  clients="$(tmux_cmd display-message -p -t "$target" '#{session_attached}')"
  last_active="$(tmux_cmd display-message -p -t "$target" '#{t/p:session_activity}')"

  window_word="windows"
  [[ "$window_count" == "1" ]] && window_word="window"

  if [[ "$clients" == "0" ]]; then
    client_phrase="detached"
  elif [[ "$clients" == "1" ]]; then
    client_phrase="1 attached client"
  else
    client_phrase="$clients attached clients"
  fi

  printf '%s - %s %s - %s - last active %s\n' "$name" "$window_count" "$window_word" "$client_phrase" "$last_active"
  if [[ "$clients" != "0" ]]; then
    printf '\nClients\n'
    tmux_cmd list-clients -t "$target" -F '  #{=999:client_name} #{client_width}x#{client_height} #{?client_active,active,inactive}'
  fi
  printf '\nWindows\n'
  tmux_cmd list-windows -t "$target" -F '#{?window_active,*, } #{window_index}: #{=999:window_name} (#{window_panes} panes) #{=999:pane_current_path}'
  printf '\nPanes\n'
  tmux_cmd list-panes -s -t "$target" -F '  #{window_index}.#{pane_index} #{?pane_active,*, } #{=999:pane_current_command} #{=999:pane_current_path}'

  active_pane_id="$(tmux_cmd display-message -p -t "$target" '#{pane_id}' 2>/dev/null || true)"
  if [[ -n "$active_pane_id" ]]; then
    printf '\nActive Pane Output\n'
    active_output="$(tmux_cmd capture-pane -p -t "$active_pane_id" -S -20 2>/dev/null || true)"
    active_output="$(last_nonempty_lines 20 "$active_output")"
    if [[ -n "$active_output" ]]; then
      print_indented_lines "$active_output"
    else
      printf '  (no visible output)\n'
    fi
  fi
}

trim_trailing_space() {
  local value="$1"

  while [[ "$value" == *[[:space:]] ]]; do
    value="${value%?}"
  done
  printf '%s\n' "$value"
}

resolve_session_name_to_id() {
  local session_name="$1"
  local candidate_id candidate_name trimmed_name trimmed_id
  local trimmed_matches=0

  while IFS=$'\t' read -r candidate_id candidate_name; do
    [[ -n "$candidate_id" ]] || continue

    if [[ "$candidate_name" == "$session_name" ]]; then
      printf '%s\n' "$candidate_id"
      return 0
    fi

    trimmed_name="$(trim_trailing_space "$candidate_name")"
    if [[ "$trimmed_name" == "$session_name" ]]; then
      trimmed_matches=$((trimmed_matches + 1))
      trimmed_id="$candidate_id"
    fi
  done < <(tmux_cmd list-sessions -F $'#{session_id}\t#{=999:session_name}')

  if [[ "$trimmed_matches" == "1" ]]; then
    printf '%s\n' "$trimmed_id"
    return 0
  fi

  return 1
}

resolve_selected_id() {
  local selected="$1" remainder
  local line selected_id session_name resolved_id candidate_id

  while IFS= read -r line; do
    [[ -n "$line" ]] || continue

    selected_id="$(trim_trailing_space "${line%%$'\t'*}")"
    if [[ "$selected_id" == \$* ]] && tmux_cmd has-session -t "$selected_id" 2>/dev/null; then
      candidate_id="$selected_id"
      continue
    fi

    [[ "$line" == *$'\t'* ]] || continue

    # Some fzf options from FZF_DEFAULT_OPTS can make fzf print extra lines
    # (for example --print-query) or the transformed display row instead of the
    # original row (for example --no-sort with --with-nth). For transformed rows,
    # field 2 is the padded session name.
    remainder="${line#*$'\t'}"
    session_name="${remainder%%$'\t'*}"
    session_name="$(trim_trailing_space "$session_name")"
    [[ -n "$session_name" ]] || continue

    resolved_id="$(resolve_session_name_to_id "$session_name" || true)"
    if [[ -n "$resolved_id" ]]; then
      candidate_id="$resolved_id"
    fi
  done <<<"$selected"

  [[ -n "${candidate_id:-}" ]] || return 1
  printf '%s\n' "$candidate_id"
}

fzf_supports_tmux_popup() {
  [[ -z "${TMUX_FZF_DISABLE_TMUX:-}" ]] && inside_tmux_client && fzf_supports '--tmux'
}

fzf_help() {
  if [[ -z "${__TMUX_FZF_HELP_CACHE+x}" ]]; then
    __TMUX_FZF_HELP_CACHE="$(fzf --help 2>/dev/null || true)"
  fi
}

fzf_supports() {
  local option="$1"
  fzf_help
  [[ "$__TMUX_FZF_HELP_CACHE" == *"$option"* ]]
}

fzf_supports_preview_threshold() {
  fzf_help
  [[ "$__TMUX_FZF_HELP_CACHE" == *SIZE_THRESHOLD* ]]
}

tmux_supports_display_popup() {
  local line

  while IFS= read -r line; do
    if [[ "$line" == display-popup* ]]; then
      return 0
    fi
  done < <(tmux_cmd list-commands 2>/dev/null)

  return 1
}

run_in_tmux_popup() {
  local helper quoted_helper

  helper="$(script_path)"
  printf -v quoted_helper '%q' "$helper"
  tmux_cmd display-popup -E -w 90% -h 70% -T ' sessions ' "TMUX_FZF_SWITCH_POPUP=1 $quoted_helper"
}

pick_session() {
  local fzf_cmd selected selected_id current_id helper quoted_helper list_command preview_window use_read0
  local -a fzf_args

  if ! fzf_cmd="$(list_sessions)" || [[ -z "$fzf_cmd" ]]; then
    display_tmux_message "No tmux sessions found"
    return
  fi

  if [[ "$(line_count "$fzf_cmd")" == "1" ]]; then
    selected_id="${fzf_cmd%%$'\t'*}"
    current_id="$(current_tmux_session_id || true)"
    if [[ -n "$current_id" ]]; then
      if [[ "$selected_id" != "$current_id" ]]; then
        tmux_cmd switch-client -t "$selected_id" 2>/dev/null || display_tmux_message "Unable to switch tmux session"
      else
        display_tmux_message "Only one tmux session"
      fi
      return
    fi

    if [[ -n "${TMUX:-}" ]]; then
      unset TMUX
    fi
    exec tmux attach-session -t "$selected_id"
  fi

  if ! command -v fzf >/dev/null 2>&1; then
    fallback_choose_tree
    return
  fi

  current_id="$(current_tmux_session_id || true)"
  if [[ -n "$current_id" && -z "${TMUX_FZF_SWITCH_POPUP:-}" ]] && ! fzf_supports_tmux_popup; then
    # Older fzf builds need a real popup pane because run-shell has no TTY.
    if tmux_supports_display_popup; then
      if ! run_in_tmux_popup; then
        display_tmux_message "Unable to open tmux session popup"
        return 1
      fi
    else
      fallback_choose_tree
    fi
    return
  fi

  helper="$(script_path)"
  printf -v quoted_helper '%q' "$helper"
  use_read0=0
  if fzf_supports '--read0'; then
    use_read0=1
  fi

  list_command="$quoted_helper --list"
  if [[ "$use_read0" == "1" ]]; then
    list_command="$quoted_helper --list0"
  fi
  if fzf_supports '--header-lines'; then
    fzf_cmd="$(session_header; printf '%s\n' "$fzf_cmd")"
    list_command="$quoted_helper --list-with-header"
    if [[ "$use_read0" == "1" ]]; then
      list_command="$quoted_helper --list0-with-header"
    fi
  fi

  preview_window='right:60%:wrap'
  if fzf_supports_preview_threshold; then
    preview_window='right:60%:wrap,<100(down:45%:wrap)'
  fi

  fzf_args=(
    --delimiter=$'\t'
    --with-nth='2..'
    --nth='2..'
    --layout=reverse
    --cycle
    +m
    --prompt='session> '
    --header='enter switch | ctrl-/ toggle preview | ctrl-r refresh | esc cancel'
    --preview="$quoted_helper --preview {1}"
    --preview-window="$preview_window"
    --bind="ctrl-/:toggle-preview,ctrl-r:reload($list_command)"
  )

  if fzf_supports '--highlight-line'; then
    fzf_args+=(--highlight-line)
  fi

  if fzf_supports '--track'; then
    fzf_args+=(--track)
  fi

  if fzf_supports '--tabstop'; then
    fzf_args+=(--tabstop=1)
  fi

  if fzf_supports '--header-lines'; then
    fzf_args+=(--header-lines=1)
  fi

  if [[ "$use_read0" == "1" ]]; then
    fzf_args+=(--read0)
  fi

  if [[ -z "${TMUX_FZF_SWITCH_POPUP:-}" ]] && fzf_supports_tmux_popup; then
    fzf_args+=(--tmux 'center,90%,70%,border-native')
  fi

  if [[ "$use_read0" == "1" ]]; then
    selected="$(printf '%s\n' "$fzf_cmd" | null_terminate_lines | fzf "${fzf_args[@]}" | nul_to_lines || true)"
  else
    selected="$(printf '%s\n' "$fzf_cmd" | fzf "${fzf_args[@]}" | nul_to_lines || true)"
  fi
  selected_id="$(resolve_selected_id "$selected" || true)"

  [[ -n "$selected_id" ]] || return 0

  if ! tmux_cmd has-session -t "$selected_id" 2>/dev/null; then
    display_tmux_message "Selected tmux session no longer exists"
    return 0
  fi

  current_id="$(current_tmux_session_id || true)"
  if [[ -n "$current_id" ]]; then
    if [[ "$selected_id" != "$current_id" ]]; then
      tmux_cmd switch-client -t "$selected_id" 2>/dev/null || display_tmux_message "Unable to switch tmux session"
    fi
  else
    if [[ -n "${TMUX:-}" ]]; then
      unset TMUX
    fi
    exec tmux attach-session -t "$selected_id"
  fi
}

ensure_usable_term
if ! command -v tmux >/dev/null 2>&1; then
  display_tmux_message "tmux is required for tmux session switching"
  exit 1
fi
if tmux_client_is_live; then
  TMUX_CLIENT_LIVE=1
fi

case "${1:-}" in
  --list)
    list_sessions
    ;;
  --list-with-header)
    session_header
    list_sessions
    ;;
  --list0)
    list_sessions | null_terminate_lines
    ;;
  --list0-with-header)
    (session_header; list_sessions) | null_terminate_lines
    ;;
  --preview)
    if [[ -z "${2:-}" ]]; then
      printf 'No session selected\n'
      exit 0
    fi
    preview_session "$2"
    ;;
  --resolve-selected-id)
    if [[ -n "${2+x}" ]]; then
      selected="$2"
    else
      selected="$(cat)"
    fi
    resolve_selected_id "$selected"
    ;;
  --choose-tree)
    fallback_choose_tree
    ;;
  *)
    pick_session
    ;;
esac
