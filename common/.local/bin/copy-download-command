#!/usr/bin/env bash
set -euo pipefail

bin_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
Usage: copy-download-command [source_dir] [destination_base]

Builds an rsync download command for the current host and copies it to the clipboard.
- source_dir defaults to the current working directory
- destination_base defaults to ~/Downloads
EOF
}

resolve_copy_helper() {
  local helper=""

  if [[ -x "$bin_dir/osc-copy" ]]; then
    printf '%s\n' "$bin_dir/osc-copy"
    return 0
  fi

  if [[ -n "${HOME:-}" ]]; then
    for helper in \
      "$HOME/.local/bin/osc-copy" \
      "$HOME/dotfiles/common/.local/bin/osc-copy"
    do
      if [[ -x "$helper" ]]; then
        printf '%s\n' "$helper"
        return 0
      fi
    done
  fi

  if helper="$(command -v -- osc-copy 2>/dev/null)"; then
    printf '%s\n' "$helper"
    return 0
  fi

  return 1
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

src_dir="${1:-$(pwd)}"
dest_base="${2:-~/Downloads}"

src_dir="${src_dir%/}"
if [[ ! -d "$src_dir" ]]; then
  echo "Directory does not exist: $src_dir" >&2
  exit 1
fi

remote_host="${SSH_RSYNC_HOST:-$(hostname)}"
timestamp="$(date +%Y-%m-%d-%H%M%S)"
dir_name="$(basename "$src_dir")"
dest_dir="${dest_base%/}/${dir_name}-${timestamp}"

printf -v download_cmd 'rsync -avz %q:%q/ %q/' "$remote_host" "$src_dir" "$dest_dir"
download_cmd="${download_cmd//\\~/\~}"
if ! copy_helper="$(resolve_copy_helper)"; then
  printf 'copy-download-command: osc-copy not found\n' >&2
  exit 127
fi
printf '%s\n' "$download_cmd" | "$copy_helper"
printf '%s\n' "$download_cmd"
