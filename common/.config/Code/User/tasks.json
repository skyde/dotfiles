                "source \"$HOME/.local/bin/dotfiles-windows-env\" 2>/dev/null || true; if git cl format --help >/dev/null 2>&1; then git cl format; else echo \"git cl format is unavailable. Install Chromium depot_tools and ensure git-cl is on PATH.\"; fi"
