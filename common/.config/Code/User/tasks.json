// .vscode/tasks.json
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "StandardTerminal",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "sess=$(get-workspace-name 2>/dev/null || { base=${PWD%/}; base=${base##*/}; base=${base//[^A-Za-z0-9_-]/_}; printf \"%s\\n\" \"${base:-workspace}\"; }); tmux-session \"$sess\" || true"
      ],
      "windows": {
        "command": "C:\\Program Files\\Git\\bin\\bash.exe",
        "args": [
          "-lc",
          "source \"$HOME/.local/bin/dotfiles-windows-env\" 2>/dev/null || true; sess=$(get-workspace-name 2>/dev/null || { base=${PWD%/}; base=${base##*/}; base=${base//[^A-Za-z0-9_-]/_}; printf \"%s\\n\" \"${base:-workspace}\"; }); if dotfiles_tmux_available; then tmux-session \"$sess\" || exec pwsh -NoLogo; else exec pwsh -NoLogo; fi"
        ]
      },
      "presentation": {
        "echo": false,
        "clear": true,
        "reveal": "always",
        "focus": true,
        "close": true,
        "panel": "dedicated"
      },
      "runOptions": {
        "instanceLimit": 1
      },
      "problemMatcher": []
    },
    {
      "label": "Tmux: Switch to AI",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "sess=$(get-workspace-name 2>/dev/null || { base=${PWD%/}; base=${base##*/}; base=${base//[^A-Za-z0-9_-]/_}; printf \"%s\\n\" \"${base:-workspace}\"; }); $HOME/dotfiles/common/.local/bin/tmux-session \"$sess\" 2 --no-attach"
      ],
      "windows": {
        "command": "C:\\Program Files\\Git\\bin\\bash.exe",
        "args": [
          "-lc",
          "source \"$HOME/.local/bin/dotfiles-windows-env\" 2>/dev/null || true; if dotfiles_tmux_available; then sess=$(get-workspace-name 2>/dev/null || { base=${PWD%/}; base=${base##*/}; base=${base//[^A-Za-z0-9_-]/_}; printf \"%s\\n\" \"${base:-workspace}\"; }); tmux-session \"$sess\" 2 --no-attach || true; fi"
        ]
      },
      "presentation": {
        "echo": false,
        "reveal": "silent",
        "focus": false,
        "close": true,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Tmux: Switch to Terminal",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "sess=$(get-workspace-name 2>/dev/null || { base=${PWD%/}; base=${base##*/}; base=${base//[^A-Za-z0-9_-]/_}; printf \"%s\\n\" \"${base:-workspace}\"; }); $HOME/dotfiles/common/.local/bin/tmux-session \"$sess\" 3 --no-attach"
      ],
      "windows": {
        "command": "C:\\Program Files\\Git\\bin\\bash.exe",
        "args": [
          "-lc",
          "source \"$HOME/.local/bin/dotfiles-windows-env\" 2>/dev/null || true; if dotfiles_tmux_available; then sess=$(get-workspace-name 2>/dev/null || { base=${PWD%/}; base=${base##*/}; base=${base//[^A-Za-z0-9_-]/_}; printf \"%s\\n\" \"${base:-workspace}\"; }); tmux-session \"$sess\" 3 --no-attach || true; fi"
        ]
      },
      "presentation": {
        "echo": false,
        "reveal": "silent",
        "focus": false,
        "close": true,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Tmux: Kill Sessions",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "$HOME/dotfiles/common/.local/bin/kill-tmux"
      ],
      "windows": {
        "command": "C:\\Program Files\\Git\\bin\\bash.exe",
        "args": [
          "-lc",
          "source \"$HOME/.local/bin/dotfiles-windows-env\" 2>/dev/null || true; if dotfiles_tmux_available; then kill-tmux || true; fi"
        ]
      },
      "presentation": {
        "echo": false,
        "reveal": "silent",
        "focus": false,
        "close": true,
        "panel": "shared"
      },
      "problemMatcher": []
    },
