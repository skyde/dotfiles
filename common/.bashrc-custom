# shellcheck shell=bash
#
# Enhanced bash configuration aligned with the zsh setup in this repo.
# Source this file from ~/.bashrc to share the same experience across shells.
# 
# Add this line
#
# [[ -r "$HOME/.bashrc-custom" ]] && source "$HOME/.bashrc-custom"

_dotfiles_bash_interactive=0
[[ $- == *i* ]] && _dotfiles_bash_interactive=1

# Use zsh if available for interactive shells
if (( _dotfiles_bash_interactive )) && [ -t 1 ] && command -v zsh >/dev/null 2>&1; then
  SHELL="$(command -v zsh)"
  export SHELL
  exec zsh -l
fi

# -------- interactive TTY tweaks (skip in non-tty to avoid extra 'stty' call)
if (( _dotfiles_bash_interactive )) && [[ -t 0 ]]; then
  stty -ixon -ixoff
fi

# -------- fast PATH (prefer user bins; include Homebrew on Apple Silicon)
for d in "/usr/local/bin" "/opt/homebrew/bin" "$HOME/go/bin" "$HOME/bin" "$HOME/local/bin" "$HOME/.local/bin"; do
  case ":$PATH:" in
    *":$d:"*) ;;
    *) PATH="$d:$PATH" ;;
  esac
done
export PATH

# -------- editor
export EDITOR="nvim"
export VISUAL="$EDITOR"

# -------- shell options
for _dotfiles_bash_opt in autocd dotglob extglob histappend nocaseglob; do
  shopt -s "$_dotfiles_bash_opt" 2>/dev/null || true
done
unset _dotfiles_bash_opt
HISTSIZE=100000
HISTFILE="$HOME/.bash_history"
HISTFILESIZE=100000
HISTCONTROL=ignoreboth:erasedups
# if [[ $PROMPT_COMMAND != *history -a* ]]; then
#  PROMPT_COMMAND="history -a${PROMPT_COMMAND:+; $PROMPT_COMMAND}"
# fi

set -o emacs
if (( _dotfiles_bash_interactive )); then
  bind '"\e[1;5C": forward-word'
  bind '"\e[1;5D": backward-word'
  bind '"\e[3;5~": kill-word'
fi

# -------- prompt (Starship)
if (( _dotfiles_bash_interactive )) && command -v starship >/dev/null 2>&1; then
  eval "$(starship init bash)"
fi

# -------- completion
if (( _dotfiles_bash_interactive )); then
  if ! shopt -oq posix; then
    if [[ -r /usr/share/bash-completion/bash_completion ]]; then
      # shellcheck disable=SC1091
      source /usr/share/bash-completion/bash_completion
    elif [[ -r /etc/bash_completion ]]; then
      # shellcheck disable=SC1091
      source /etc/bash_completion
    fi
  fi
  bind 'set show-all-if-ambiguous on'
  bind 'set menu-complete-display-prefix on'
  bind 'set completion-ignore-case on'
  bind 'TAB:menu-complete'
fi

# -------- zoxide (smart cd)
if (( _dotfiles_bash_interactive )) && command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init bash)"
fi

_dotfiles_bash_tmux_client_live() {
  [[ -n "${TMUX:-}" ]] || return 1
  command -v tmux >/dev/null 2>&1 || return 1
  tmux display-message -p '#{pane_id}' >/dev/null 2>&1
}

_dotfiles_bash_fzf_supports_tmux() {
  local help

  help="$(fzf --help 2>/dev/null || true)"
  [[ "$help" == *--tmux* ]]
}

_dotfiles_bash_fzf_history_candidates() {
  local line trimmed seen=$'\n'

  while IFS= read -r line; do
    trimmed="${line#"${line%%[![:space:]]*}"}"
    [[ -n "$trimmed" ]] || continue
    [[ "$seen" == *$'\n'"$trimmed"$'\n'* ]] && continue
    seen="${seen}${trimmed}"$'\n'
    printf '%s\n' "$trimmed"
  done < <(builtin fc -lnr -2147483648 2>/dev/null)
}

# -------- fzf setup
if (( _dotfiles_bash_interactive )) && command -v fzf >/dev/null 2>&1; then
  _fzf_ctrl_r_opts="--height=80% --min-height=20 --layout=reverse --wrap --prompt='History> ' --with-nth=2.. --preview='printf \"%s\n\" {2..}' --preview-window='down,4,wrap,hidden' --bind='alt-p:toggle-preview' --header='Ctrl-R sort | Alt-R all | Alt-P preview | Ctrl-/ wrap'"
  # Prefer fzf's native tmux popup for Ctrl-R, unless local config opts into
  # fzf-tmux through FZF_TMUX/FZF_TMUX_OPTS.
  if [[ "${FZF_TMUX:-0}" == 0 && -z "${FZF_TMUX_OPTS:-}" ]] &&
    _dotfiles_bash_tmux_client_live &&
    _dotfiles_bash_fzf_supports_tmux; then
    _tmux_version="$(tmux -V 2>/dev/null)"
    _tmux_version="${_tmux_version#tmux }"
    if [[ "$_tmux_version" =~ ^([4-9]|[1-9][0-9])\. ]] || [[ "$_tmux_version" =~ ^3\.([3-9]|[1-9][0-9]) ]]; then
      _fzf_ctrl_r_opts="--tmux=center,90%,70% $_fzf_ctrl_r_opts"
    fi
  fi
  export FZF_CTRL_R_OPTS="$_fzf_ctrl_r_opts${FZF_CTRL_R_OPTS:+ $FZF_CTRL_R_OPTS}"

  _fzf_loaded=0
  for dir in \
    "/usr/share/fzf" \
    "/usr/local/opt/fzf/shell" \
    "/opt/homebrew/opt/fzf/shell" \
    "/usr/share/doc/fzf/examples" \
    "$HOME/.fzf/shell" \
    "$HOME/.fzf"
  do
    if [[ -r "$dir/key-bindings.bash" ]]; then
      # shellcheck disable=SC1091
      source "$dir/key-bindings.bash"
      _fzf_loaded=1
      break
    fi
  done

  for dir in \
    "/usr/share/fzf" \
    "/usr/local/opt/fzf/shell" \
    "/opt/homebrew/opt/fzf/shell" \
    "/usr/share/doc/fzf/examples" \
    "$HOME/.fzf/shell" \
    "$HOME/.fzf"
  do
    if [[ -r "$dir/completion.bash" ]]; then
      # shellcheck disable=SC1091
      source "$dir/completion.bash"
      break
    fi
  done

  if (( ! _fzf_loaded )) && fzf --bash >/dev/null 2>&1; then
    eval "$(fzf --bash)"
    _fzf_loaded=1
  fi

  if command -v fd >/dev/null 2>&1; then
    export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
  fi

  export FZF_DEFAULT_OPTS="${FZF_DEFAULT_OPTS:-} \
    --reverse \
    --ansi \
    --info=inline \
    --style=minimal \
    --no-cycle \
    --color=prompt:#80a0ff,pointer:#ff5000,marker:#afff5f,hl:215,hl+:215"

  if (( ! _fzf_loaded )); then
    __fzf_history_widget_fallback() {
      local selected
      selected=$(_dotfiles_bash_fzf_history_candidates |
        fzf --height=80% --layout=reverse --min-height=20 \
            --tiebreak=index --no-sort --scheme=history --wrap \
            --preview='printf "%s\n" {}' --preview-window='down,4,wrap,hidden' \
            --bind='ctrl-r:toggle-sort,alt-p:toggle-preview' \
            --header='Ctrl-R sort | Alt-P preview | Ctrl-/ wrap' \
            --prompt='History> ' --style=minimal --query "$READLINE_LINE") || return
      READLINE_LINE=$selected
      READLINE_POINT=${#selected}
    }
    bind -x '"\C-r": "__fzf_history_widget_fallback"'
  fi
  unset _fzf_ctrl_r_opts _fzf_loaded _tmux_version
fi

# -------- safer Git defaults where tools may be missing
if ! command -v delta >/dev/null 2>&1 || ! command -v code >/dev/null 2>&1; then
  git() {
    local cfg=()
    if ! command -v delta >/dev/null 2>&1; then
      cfg+=(-c core.pager=less -c interactive.diffFilter=cat)
    fi
    if ! command -v code >/dev/null 2>&1; then
      if command -v nvim >/dev/null 2>&1; then
        cfg+=(-c merge.tool=nvimdiff3 -c difftool.tool=nvimdiff)
      else
        cfg+=(-c merge.tool=vimdiff -c difftool.tool=vimdiff)
      fi
    fi
    command git "${cfg[@]}" "$@"
  }
fi

# -------- VS Code Remote SSH: pick a live IPC socket before delegating to code
code() {
  local socket socket_dir found=0
  if command -v nc >/dev/null 2>&1; then
    socket_dir="${DOTFILES_VSCODE_IPC_DIR:-/run/user/$UID}"
    for socket in "${VSCODE_IPC_HOOK_CLI:-}" "$socket_dir"/vscode-ipc-*.sock; do
      if [[ -S "$socket" ]] && nc -z -U "$socket" >/dev/null 2>&1; then
        export VSCODE_IPC_HOOK_CLI="$socket"
        found=1
        break
      fi
    done
    if [[ "$found" == "0" ]]; then
      unset VSCODE_IPC_HOOK_CLI
    fi
  fi
  command code "$@"
}

# -------- aliases
alias grep='grep --color=auto'
alias stow_apply='$HOME/dotfiles/apply.sh'
alias stow_init='$HOME/dotfiles/init.sh'
alias stow_update='$HOME/dotfiles/update.sh && $HOME/dotfiles/apply.sh'
alias stow_update_init_auto='$HOME/dotfiles/update.sh && AUTO_INSTALL=1 $HOME/dotfiles/init.sh'

export RIPGREP_CONFIG_PATH="$HOME/.ripgreprc"
export BAT_THEME="Visual Studio Dark+"

if command -v bat >/dev/null 2>&1; then
  alias cat='bat'
elif command -v batcat >/dev/null 2>&1; then
  alias bat='batcat'
  alias cat='batcat'
fi

if command -v eza >/dev/null 2>&1; then
  alias ls='eza --color=auto --group-directories-first'
  alias ll='eza -al --color=auto --group-directories-first'
  alias la='eza -a --color=auto --group-directories-first'
  alias tree='eza --tree --icons --group-directories-first'
fi

if ! command -v fd >/dev/null 2>&1 && command -v fdfind >/dev/null 2>&1; then
  alias fd='fdfind'
fi

# -------- file managers that cd to the last visited dir
y() {
  local tmp cwd yazi_cmd rc
  tmp="$(mktemp -t yazi-cwd.XXXXXX)"
  if [[ -x "$HOME/.local/bin/yazi" ]]; then
    yazi_cmd="$HOME/.local/bin/yazi"
  elif command -v yazi >/dev/null 2>&1; then
    yazi_cmd="$(command -v yazi)"
  else
    printf '%s\n' "y: yazi not found" >&2
    rm -f -- "$tmp"
    return 127
  fi
  "$yazi_cmd" "$@" --cwd-file="$tmp"
  rc=$?
  if [[ -r "$tmp" ]]; then
    cwd=$(<"$tmp")
  else
    cwd=""
  fi
  rm -f -- "$tmp"
  if (( rc == 0 )) && [[ -n $cwd && $cwd != "$PWD" ]]; then
    builtin cd -- "$cwd" || return
  fi
  return "$rc"
}

# -------- machine-specific overrides
unset _dotfiles_bash_interactive

# shellcheck disable=SC1091
[[ -r "$HOME/.bashrc.local" ]] && source "$HOME/.bashrc.local"
