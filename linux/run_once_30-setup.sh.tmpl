#!/usr/bin/env bash
set -e

# Use sudo only if not running as root
if [ "$(id -u)" -eq 0 ]; then
    SUDO=""
else
    SUDO="sudo"
fi

COMMON_APPS=(
{{- include "common_apps.txt" -}}
)

echo "Running Linux setup using apt..."
if command -v apt-get >/dev/null 2>&1; then
    $SUDO apt-get update -y -qq || true
    
    # Install prerequisites
    $SUDO apt-get install -y curl wget software-properties-common apt-transport-https ca-certificates gnupg lsb-release || true
    
    # Add repositories for latest versions
    echo "Adding repositories for latest packages..."
    
    # Add Neovim PPA for latest version
    if ! grep -q "neovim" /etc/apt/sources.list.d/neovim.list 2>/dev/null; then
        $SUDO add-apt-repository ppa:neovim-ppa/stable -y || true
    fi
    
    # Add Git PPA for latest version
    if ! grep -q "git-core" /etc/apt/sources.list.d/git-core.list 2>/dev/null; then
        $SUDO add-apt-repository ppa:git-core/ppa -y || true
    fi
    
    # Add LLVM repository for latest version
    if ! grep -q "llvm" /etc/apt/sources.list.d/llvm.list 2>/dev/null; then
        wget -qO- https://apt.llvm.org/llvm.sh | $SUDO bash -s all || true
    fi
    
    # Update package lists after adding repositories
    $SUDO apt-get update -y -qq || true
    
    # Install packages with latest versions
    for pkg in "${COMMON_APPS[@]}"; do
        case "$pkg" in
            "fd")
                # Install fd-find from default repos (latest available)
                $SUDO apt-get install -y fd-find || true
                ;;
            "nvim")
                # Install neovim from PPA
                $SUDO apt-get install -y neovim || true
                ;;
            "ripgrep")
                # Install ripgrep from default repos (latest available)
                $SUDO apt-get install -y ripgrep || true
                ;;
            "fzf")
                # Install fzf from default repos (latest available)
                $SUDO apt-get install -y fzf || true
                ;;
            "bat")
                # Install bat from default repos (latest available)
                $SUDO apt-get install -y bat || true
                ;;
            "delta")
                # Install git-delta from default repos (latest available)
                $SUDO apt-get install -y git-delta || true
                ;;
            "less")
                # Install less from default repos
                $SUDO apt-get install -y less || true
                ;;
            "llvm")
                # Install LLVM from official repository
                $SUDO apt-get install -y llvm || true
                ;;
            "git")
                # Install git from PPA
                $SUDO apt-get install -y git || true
                ;;
            *)
                # Try to install any other packages
                $SUDO apt-get install -y "$pkg" || true
                ;;
        esac
    done
    
    # Install fonts (Linux-specific: fonts-firacode)
    $SUDO apt-get install -y fonts-firacode || true
else
    echo "apt-get not found. Skipping package installs."
fi

echo "Linux setup complete!"
