#!/usr/bin/env bash
set -e

# Use sudo only if not running as root
if [ "$(id -u)" -eq 0 ]; then
    SUDO=""
else
    SUDO="sudo"
fi

COMMON_APPS=(
{{- include "common_apps.txt" -}}
)

echo "Installing Homebrew and all packages using Homebrew on Debian..."

# Install Homebrew if not present
if ! command -v brew >/dev/null 2>&1; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" || true
    
    # Add Homebrew to PATH
    if [ -f "/home/linuxbrew/.linuxbrew/bin/brew" ]; then
        eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    elif [ -f "/opt/homebrew/bin/brew" ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    fi
fi

# Install all packages from common_apps.txt using Homebrew
echo "Installing packages using Homebrew: ${COMMON_APPS[*]}"
for pkg in "${COMMON_APPS[@]}"; do
    case "$pkg" in
        "fd")
            echo "Installing fd-find..."
            brew install fd || true
            ;;
        "llvm")
            echo "Installing llvm..."
            brew install llvm || true
            ;;
        *)
            echo "Installing $pkg..."
            brew install "$pkg" || true
            ;;
    esac
done

# Install fonts using Homebrew
echo "Installing Fira Code font using Homebrew..."
brew tap homebrew/cask-fonts || true
brew install --cask font-fira-code || true

# Install additional development tools using Homebrew
echo "Installing additional development tools..."
brew install cmake pkg-config || true

# Create symlinks to make packages available system-wide
echo "Creating symlinks for packages..."
$SUDO ln -sf $(brew --prefix)/bin/* /usr/local/bin/ || true

# Remove any apt-installed versions to avoid conflicts
echo "Removing any apt-installed versions to avoid conflicts..."
$SUDO apt-get remove -y neovim neovim-runtime ripgrep fd-find fzf bat delta less llvm || true
$SUDO rm -f /usr/bin/nvim /usr/bin/vim /usr/bin/rg /usr/bin/fd /usr/bin/fzf /usr/bin/bat /usr/bin/delta /usr/bin/llvm-config || true

# Use dpkg-divert to prevent apt from overwriting our binaries
echo "Using dpkg-divert to prevent apt from overwriting our binaries..."
for binary in nvim vim rg fd fzf bat delta llvm-config; do
    $SUDO dpkg-divert --add --rename --divert /usr/bin/$binary.apt /usr/bin/$binary || true
    $SUDO ln -sf /usr/local/bin/$binary /usr/bin/$binary || true
done

# Prepend /usr/local/bin to PATH for this session
export PATH="/usr/local/bin:$PATH"

# Final debug check
echo "=== FINAL DEBUG ==="
echo "which nvim: $(which nvim)"
echo "which rg: $(which rg)"
echo "which fd: $(which fd)"
echo "which fzf: $(which fzf)"
echo "which bat: $(which bat)"
echo "which delta: $(which delta)"
echo "which llvm-config: $(which llvm-config)"
echo "nvim --version:"
nvim --version

echo "Linux setup complete using Homebrew!"
