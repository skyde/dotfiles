#!/usr/bin/env bash
set -e

# Use sudo only if not running as root
if [ "$(id -u)" -eq 0 ]; then
    SUDO=""
else
    SUDO="sudo"
fi

COMMON_APPS=(
{{- include "common_apps.txt" -}}
)

# Remove nvim from COMMON_APPS for apt install
APT_APPS=()
for pkg in "${COMMON_APPS[@]}"; do
    [ "$pkg" != "nvim" ] && APT_APPS+=("$pkg")
done

echo "Running Linux setup using apt..."
if command -v apt-get >/dev/null 2>&1; then
    $SUDO apt-get update -y -qq || true
    
    # Install prerequisites
    $SUDO apt-get install -y curl wget software-properties-common apt-transport-https ca-certificates gnupg lsb-release build-essential cmake pkg-config || true
    
    # Add repositories for latest versions
    echo "Adding repositories for latest packages..."
    
    # Add LLVM repository for latest version
    if ! grep -q "llvm" /etc/apt/sources.list.d/llvm.list 2>/dev/null; then
        wget -qO- https://apt.llvm.org/llvm.sh | $SUDO bash -s all || true
    fi
    
    # Update package lists after adding repositories
    $SUDO apt-get update -y -qq || true
    
    # Install all other packages except nvim
    for pkg in "${APT_APPS[@]}"; do
        case "$pkg" in
            "fd")
                $SUDO apt-get install -y fd-find || true
                ;;
            "llvm")
                $SUDO apt-get install -y llvm || true
                ;;
            *)
                $SUDO apt-get install -y "$pkg" || true
                ;;
        esac
    done
    
    # Install fonts (Linux-specific: fonts-firacode)
    $SUDO apt-get install -y fonts-firacode || true
else
    echo "apt-get not found. Skipping package installs."
fi

echo "Installing latest Neovim from official releases..."
NVIM_VERSION=$(curl -s https://api.github.com/repos/neovim/neovim/releases/latest | grep '"tag_name":' | cut -d'"' -f4)
echo "Latest Neovim version: $NVIM_VERSION"
if [ -n "$NVIM_VERSION" ] && [ "$NVIM_VERSION" != "null" ]; then
    $SUDO apt-get install -y ninja-build gettext cmake unzip curl || true
    cd /tmp
    wget -q "https://github.com/neovim/neovim/releases/download/${NVIM_VERSION}/nvim-linux64.tar.gz"
    if [ -f "nvim-linux64.tar.gz" ]; then
        $SUDO tar xzf nvim-linux64.tar.gz -C /opt
        $SUDO ln -sf /opt/nvim-linux64/bin/nvim /usr/local/bin/nvim
        $SUDO ln -sf /opt/nvim-linux64/bin/nvim /usr/local/bin/vim
        echo "Neovim $NVIM_VERSION installed successfully from official release"
        nvim_version_installed=$(/usr/local/bin/nvim --version | head -n1 | awk '{print $2}')
        echo "Installed Neovim version: $nvim_version_installed"
        if [ "$nvim_version_installed" != "${NVIM_VERSION#v}" ]; then
            echo "ERROR: Installed Neovim version does not match latest!"
            exit 1
        fi
    else
        echo "Failed to download Neovim archive!"
        exit 1
    fi
    cd -
else
    echo "Could not determine latest Neovim version!"
    exit 1
fi

echo "Linux setup complete!"
